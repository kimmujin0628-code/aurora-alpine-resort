        </div>
        <div class="res-field">
          <label for="checkout">Departure</label>
          <input type="date" id="checkout" name="checkout" aria-label="Check-out date">
        </div>
        <div class="res-field">
          <label for="guests">Guests</label>
          <select id="guests" name="guests" aria-label="Number of guests">
